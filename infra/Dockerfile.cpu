# ── Stage 1: deps ────────────────────────────────────────────────────────────
# uv.lock contains platform-specific entries: linux gets torchvision==0.27.0+cpu
# from the pytorch-cpu index (no CUDA bloat), win32 gets the CUDA build.
# Using --frozen pins to the lock-file resolution; --extra ml adds open-clip-torch
# and the rest of the visual-search stack.
FROM python:3.11-slim AS deps
WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock ./
# Install base deps + the [ml] extra so open-clip-torch, sentence-transformers,
# and transformers are available for the /visual-search endpoint.
RUN uv sync --frozen --no-dev --no-install-project --extra ml

# ── Stage 2: runtime ─────────────────────────────────────────────────────────
FROM python:3.11-slim AS runtime
WORKDIR /app

COPY --from=deps /app/.venv /app/.venv
ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1
ENV PORT=8000

# Cache directories that CLIP and SBERT write model weights into.
# Located under /app so they fall inside the chown-ed subtree below and are
# readable/writeable by the non-root appuser.
# HF_HOME covers sentence-transformers (uses HuggingFace Hub download path).
# TORCH_HOME covers open_clip's torch-hub fallback (not used by openai pretrained
# which goes through HF, but set defensively for any torch.hub call).
ENV HF_HOME=/app/.cache/hf
ENV TORCH_HOME=/app/.cache/torch

COPY src/ src/
COPY app/ app/
COPY brands/ brands/
COPY config.yaml .

RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

# Create cache directories before baking weights so the write succeeds as root.
RUN mkdir -p /app/.cache/hf /app/.cache/torch

# ── Bake model weights at build time ─────────────────────────────────────────
# Cloud Run min-instances=0 means every cold start would otherwise re-download
# ~600 MB of FashionCLIP weights from the internet on first /visual-search call.
# Baking them into the image layer eliminates that per-cold-start latency hit.
#
# FashionCLIP (patrickjohncyh/fashion-clip) is loaded via transformers'
# CLIPModel/CLIPProcessor, which use HuggingFace Hub; HF_HOME controls where it caches.
#
# SBERT (all-MiniLM-L6-v2) is intentionally NOT baked: the visual-search route
# no longer uses SBERT (pure FashionCLIP-512 path). sentence-transformers remains
# installed via --extra ml in case other tooling needs it, but downloading its
# weights at image build time would add ~90 MB for zero serving benefit.
RUN python -c "from transformers import CLIPModel, CLIPProcessor; CLIPModel.from_pretrained('patrickjohncyh/fashion-clip'); CLIPProcessor.from_pretrained('patrickjohncyh/fashion-clip')"

# chown only the directories appuser actually needs to WRITE at runtime:
# data/, indices/, checkpoints/ (GCS-synced brand assets, created empty here since
# app/storage.py populates them at startup) and .cache/ (HF/torch cache dirs — see
# comment above). Deliberately NOT `chown -R /app`: /app/.venv is the entire ML
# dependency tree (~1.7 GB, ~39k files) that appuser only ever needs to READ, and a
# recursive chown over it was costing several minutes on every build with no
# functional benefit (default COPY permissions already make it world-readable).
RUN adduser --disabled-password --gecos "" --no-create-home --uid 1001 appuser \
    && mkdir -p /app/data /app/indices /app/checkpoints \
    && chown -R appuser /app/.cache /app/data /app/indices /app/checkpoints
USER appuser

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD curl -f http://localhost:${PORT}/health || exit 1

# Cloud Run injects PORT at runtime; use shell form so $PORT is evaluated
CMD ["sh", "-c", "uvicorn app.api.main:app --host 0.0.0.0 --port ${PORT}"]
